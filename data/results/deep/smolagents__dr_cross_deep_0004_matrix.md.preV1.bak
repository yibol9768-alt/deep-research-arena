import requests
from bs4 import BeautifulSoup
import re
import time

wiki_base = "http://localhost:8090"
wiki_path = "/content/wikipedia_en_all_nopic"

# Test accessing a Wikipedia article
articles_to_check = [
    "Photography", "Digital_single-lens_reflex_camera", "Mirrorless_camera",
    "Aperture", "Shutter_speed", "Film_speed", "Depth_of_field",
    "Exposure_(photography)", "Focal_length", "Camera",
    "Lens_(optics)", "Tripod_(photography)", "Flash_(photography)",
    "Image_stabilization", "Zoom_lens", "Digital_camera",
    "Photographic_filter", "Memory_card", "Camera_strap",
    "Video_camera", "Camera_phone", "Light-emitting_diode",
    "Optical_zoom", "Megapixel", "Battery_(electricity)"
]

for article in articles_to_check:
    url = f"{wiki_base}{wiki_path}/{article}"
    try:
        resp = requests.get(url, timeout=5)
        if resp.status_code == 200:
            soup = BeautifulSoup(resp.text, 'html.parser')
            title = soup.title.string if soup.title else "No title"
            # Get first paragraph
            p = soup.find('p')
            first_p = p.get_text(strip=True)[:150] if p else "No content"
            print(f"OK: {article} - {resp.status_code}")
        else:
            print(f"FAIL: {article} - {resp.status_code}")
    except Exception as e:
        print(f"ERROR: {article} - {e}")
    time.sleep(0.1)
