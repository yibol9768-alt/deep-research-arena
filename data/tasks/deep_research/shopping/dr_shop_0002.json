{
  "task_id": "dr_shop_0002",
  "sites": ["shopping"],
  "intent": "On the One Stop Market, browse the 'Beauty & Personal Care > Hair Care > Shampoo & Conditioner' listing. Report the three least expensive shampoos/conditioners that have a rating of at least 3.0 stars, sorted by price ascending. For each, provide name, price, rating, product URL.",
  "start_url": "__SHOPPING__/beauty-personal-care/hair-care/shampoo-conditioner.html",
  "storage_state": null,
  "require_login": false,
  "difficulty": 2,
  "expected_steps": 6,
  "author_notes": "Shampoo/conditioner listing; sort by price asc, filter rating >= 3.",

  "report_schema": {
    "type": "object",
    "properties": {
      "products": {
        "type": "array",
        "minItems": 3,
        "maxItems": 3,
        "items": {
          "type": "object",
          "required": ["name", "price", "rating", "product_url"],
          "properties": {
            "name":        {"type": "string"},
            "price":       {"type": "number", "minimum": 0},
            "rating":      {"type": "number", "minimum": 0, "maximum": 5},
            "product_url": {"type": "string"}
          }
        }
      }
    },
    "required": ["products"]
  },

  "citation_policy": {
    "required_for": ["products[*].price"],
    "must_be_in_domain": ["__SHOPPING__"],
    "min_distinct_sources": 3
  },

  "eval": {
    "eval_types": ["report_match", "citation_check"],
    "report_expected": {
      "products": [
        {"rating_min": 3.0, "price_range": [0.01, 200.0], "url_regex": "^http://localhost:7770/"},
        {"rating_min": 3.0, "price_range": [0.01, 200.0], "url_regex": "^http://localhost:7770/"},
        {"rating_min": 3.0, "price_range": [0.01, 200.0], "url_regex": "^http://localhost:7770/"}
      ]
    }
  }
}
