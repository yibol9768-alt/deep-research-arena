\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces Comparison with representative deep research benchmarks. \textbf  {Reprod.}~= reproducible across time; \textbf  {M-src}~= heterogeneous multi-source; \textbf  {Inter.}~= interactive sites (not pure IR); \textbf  {Intent}~= structured intent taxonomy; \textbf  {Cite-GT}~= ground truth at the citation level (must-cite URL set per task); \textbf  {Task-GT}~= deterministic task-completion check (e.g., programmatic state). \textsc  {SandboxDR}{} contributes Cite-GT where most prior DR benchmarks lack any citation-level ground truth; WebArena and DRBench-E contribute Task-GT (functional checks) which we do not provide.}}{4}{table.caption.11}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{tab:comparison}{{1}{4}{Comparison with representative deep research benchmarks. \textbf {Reprod.}~= reproducible across time; \textbf {M-src}~= heterogeneous multi-source; \textbf {Inter.}~= interactive sites (not pure IR); \textbf {Intent}~= structured intent taxonomy; \textbf {Cite-GT}~= ground truth at the citation level (must-cite URL set per task); \textbf {Task-GT}~= deterministic task-completion check (e.g., programmatic state). \ours {} contributes Cite-GT where most prior DR benchmarks lack any citation-level ground truth; WebArena and DRBench-E contribute Task-GT (functional checks) which we do not provide}{table.caption.11}{}}
