\@writefile{lot}{\contentsline {table}{\numberline {3}{\ignorespaces Headline leaderboard under the V3 truthfulness-gated composite (Eq.~\ref {eq:composite}, $\phi {=}0.1$). Bradley-Terry Elo (1000-anchor, mean-centered, scale $400/\ln 10$) fit by MM-iteration with weak Bayesian smoothing (pseudo-count 0.5 to keep zero-win agents identifiable); 95\% CIs from 1{,}000 percentile bootstrap resamples over 1{,}080 head-to-head battles ($\binom  {9}{2}=36$ pairs $\times $ 30 common tasks). All 9 agents are restricted to the symmetric 30-task common subset for the headline; the n=56 CAMEL-AI extension (\S  \ref {sec:limitations}) is reported as an appendix sensitivity check, not in this table. The top~3 form a clear tier separated from the rest by ${>}300$ Elo points; bottom~6 spread is partly driven by framework-integration issues (\S  \ref {sec:errors}, particularly STORM and II-Researcher).}}{9}{table.caption.19}\protected@file@percent }
\newlabel{tab:leaderboard}{{3}{9}{Headline leaderboard under the V3 truthfulness-gated composite (Eq.~\ref {eq:composite}, $\phi {=}0.1$). Bradley-Terry Elo (1000-anchor, mean-centered, scale $400/\ln 10$) fit by MM-iteration with weak Bayesian smoothing (pseudo-count 0.5 to keep zero-win agents identifiable); 95\% CIs from 1{,}000 percentile bootstrap resamples over 1{,}080 head-to-head battles ($\binom {9}{2}=36$ pairs $\times $ 30 common tasks). All 9 agents are restricted to the symmetric 30-task common subset for the headline; the n=56 CAMEL-AI extension (\S \ref {sec:limitations}) is reported as an appendix sensitivity check, not in this table. The top~3 form a clear tier separated from the rest by ${>}300$ Elo points; bottom~6 spread is partly driven by framework-integration issues (\S \ref {sec:errors}, particularly STORM and II-Researcher)}{table.caption.19}{}}
\@writefile{lot}{\contentsline {table}{\numberline {4}{\ignorespaces V3 composite mean stratified by intent type, on the symmetric $n{=}30$ common subset. ``$n$'' is the number of tasks in each intent cell on this subset. \textbf  {Bold}: per-intent winner.}}{9}{table.caption.22}\protected@file@percent }
\newlabel{tab:intent}{{4}{9}{V3 composite mean stratified by intent type, on the symmetric $n{=}30$ common subset. ``$n$'' is the number of tasks in each intent cell on this subset. \textbf {Bold}: per-intent winner}{table.caption.22}{}}
