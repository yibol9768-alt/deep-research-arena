# Keep curated *.md leaderboards under data/results/, drop raw dumps
data/results/*.json
data/results/*.answer.txt
data/results/q_*

# ...but keep the analysis JSONs that drive paper tables
!data/results/length_ablation.json
!data/results/error_taxonomy.json
!data/results/irt_calibration.json
!data/results/arena_elo_ED.json
!data/results/arena_final.json

