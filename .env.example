# Copy to `.env` and fill in.

# Anthropic-compat endpoint pointing at Zhipu coding-plan (or any other
# Anthropic-compatible provider). Don't commit your real token.
ANTHROPIC_BASE_URL=https://open.bigmodel.cn/api/anthropic
ANTHROPIC_AUTH_TOKEN=your_zhipu_coding_plan_token_here

# Site map for the runner
SHOPPING=http://localhost:7770
REDDIT=http://localhost:9999
GITLAB=http://localhost:8023

# Optional: model overrides
GLM_MODEL=glm-5.1
JUDGE_MODEL=glm-5.1
PAIRWISE_JUDGE_MODEL=glm-5.1
